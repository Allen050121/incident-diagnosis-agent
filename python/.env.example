# Database Configuration
DB_HOST=192.168.85.66
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=root
DB_NAME=incident_db

# Redis Configuration
REDIS_HOST=192.168.85.66
REDIS_PORT=6379

# Elasticsearch / Runbook RAG
ELASTICSEARCH_URL=http://192.168.85.66:9200
RUNBOOK_INDEX=runbooks

# Metrics
# Use "fake" for deterministic local demos/tests, or "prometheus" to query the VM Prometheus.
METRICS_PROVIDER=fake
PROMETHEUS_URL=http://192.168.85.66:9090

# Logs
# Use "fake" for deterministic local demos/tests, or "file" to read Spring Boot log files.
LOG_PROVIDER=fake
LOG_BASE_DIR=../logs

# Agent mode
# Use "rule" for deterministic demos/evaluation, or "llm" to call DeepSeek with rule fallback.
AGENT_MODE=rule

# DeepSeek LLM
# Get your API Key: https://platform.deepseek.com/api_keys
LLM_API_KEY=your-deepseek-api-key-here
LLM_MODEL=deepseek-v4-flash
LLM_BASE_URL=https://api.deepseek.com
